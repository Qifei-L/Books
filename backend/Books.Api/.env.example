# Copy this file to .env for local development.
# Do not put real Railway credentials in .env.example.

# Option 1: Railway-style URL. This is converted to an Npgsql connection string by the API.
DATABASE_URL=postgresql://username:password@host:5432/books

# Option 2: Direct Npgsql connection string.
# If DATABASE_URL is set, it takes priority over this value.
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=books;Username=postgres;Password=postgres
