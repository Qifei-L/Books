@page "/entities"
@page "/setup/entities"
@rendermode InteractiveServer
@inject GeneralLedgerAppService Gl
@inject NavigationManager Nav

<div class="page-header">
    <div>
        <p class="eyebrow">Entity</p>
        <h1>Entities</h1>
    </div>
    <button @onclick="NewEntity">New Entity</button>
</div>

@if (editing)
{
    <section class="panel">
        <div class="section-title-row">
            <div>
                <p class="eyebrow">Entity Setup</p>
                <h2>@(form.Id.HasValue ? "Edit Entity" : "New Entity")</h2>
            </div>
        </div>
        <div class="form-grid">
            <label>Code
                <input @bind="form.Code" />
            </label>
            <label class="wide">Name
                <input @bind="form.Name" />
            </label>
            <label class="check-field">
                <span>Status</span>
                <input type="checkbox" @bind="form.IsActive" />
                Active
            </label>
        </div>
        <div class="actions-row">
            <button disabled="@(!CanSave)" @onclick="SaveEntity">Save Entity</button>
            <button class="secondary" @onclick="CancelEdit">Cancel</button>
        </div>
    </section>
}

<section class="panel">
    @if (loading)
    {
        <div class="empty">Loading entities...</div>
    }
    else if (entities.Count == 0)
    {
        <div class="empty">No entities found.</div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Status</th>
                    <th class="actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entity in entities)
                {
                    <tr>
                        <td><a href="@($"/entities/{entity.Id}")">@entity.Code</a></td>
                        <td>@entity.Name</td>
                        <td><span class="@(entity.IsActive ? "badge badge-active" : "badge badge-inactive")">@(entity.IsActive ? "Active" : "Inactive")</span></td>
                        <td class="actions">
                            <button class="text-button" @onclick="() => OpenEntity(entity.Id)">Open</button>
                            <button class="text-button" @onclick="() => EditEntity(entity)">Edit</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private List<Entity> entities = [];
    private EntityForm form = new();
    private bool loading = true;
    private bool editing;
    private bool CanSave => !string.IsNullOrWhiteSpace(form.Code) && !string.IsNullOrWhiteSpace(form.Name);

    protected override async Task OnInitializedAsync()
    {
        await LoadEntities();
    }

    private async Task LoadEntities()
    {
        loading = true;
        entities = await Gl.GetEntitiesAsync();
        loading = false;
    }

    private void NewEntity()
    {
        form = new EntityForm();
        editing = true;
    }

    private void EditEntity(Entity entity)
    {
        form = new EntityForm
        {
            Id = entity.Id,
            Code = entity.Code,
            Name = entity.Name,
            IsActive = entity.IsActive
        };
        editing = true;
    }

    private void CancelEdit() => editing = false;

    private void OpenEntity(int id) => Nav.NavigateTo($"/entities/{id}");

    private async Task SaveEntity()
    {
        var saved = await Gl.SaveEntityAsync(new EntityEditDto(form.Id, form.Code, form.Name, form.IsActive));
        editing = false;
        await LoadEntities();

        if (!form.Id.HasValue)
        {
            Nav.NavigateTo($"/entities/{saved.Id}");
        }
    }

    private sealed class EntityForm
    {
        public int? Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
    }
}
