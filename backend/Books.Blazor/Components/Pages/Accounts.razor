@page "/gl/accounts"
@page "/entities/{EntityId:int}/accounts"
@rendermode InteractiveServer
@inject GeneralLedgerAppService Gl

<div class="accounts-page">
    <section class="accounts-hero">
        <div>
            <p class="eyebrow">Entity Accounts</p>
            <h1>Chart of Accounts</h1>
            <p class="hero-copy">@SelectedEntityLabel</p>
        </div>
        <div class="actions-row compact">
            @if (selectedEntity is not null)
            {
                <a class="button-link secondary" href="@($"/entities/{selectedEntity.Id}")">Entity Detail</a>
            }
            <button class="primary-action" disabled="@(selectedEntityId == 0)" @onclick="NewAccount">
                <span class="button-symbol" aria-hidden="true">+</span>
                New Account
            </button>
        </div>
    </section>

    <section class="account-metrics" aria-label="Account summary">
        <div class="account-metric">
            <span>Total Accounts</span>
            <strong>@accounts.Count</strong>
        </div>
        <div class="account-metric">
            <span>Active</span>
            <strong>@ActiveAccountCount</strong>
        </div>
        <div class="account-metric">
            <span>Inactive</span>
            <strong>@InactiveAccountCount</strong>
        </div>
        <div class="account-metric">
            <span>Normal Debit</span>
            <strong>@DebitNormalCount</strong>
        </div>
        <div class="account-metric">
            <span>Normal Credit</span>
            <strong>@CreditNormalCount</strong>
        </div>
    </section>

    <section class="panel account-filter-panel">
        <div class="accounts-toolbar entity-toolbar">
            <label>Entity
                <select value="@selectedEntityId" @onchange="ChangeEntity">
                    @foreach (var entity in entities)
                    {
                        <option value="@entity.Id">@entity.Code - @entity.Name</option>
                    }
                </select>
            </label>
            <label class="search-field">Search
                <input placeholder="Code or account name" @bind="search" @bind:event="oninput" />
            </label>
            <label>Type
                <select @bind="typeFilter">
                    <option value="">All types</option>
                    @foreach (var type in Enum.GetValues<AccountType>())
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </label>
            <label>Status
                <select @bind="statusFilter">
                    <option value="">All statuses</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </label>
            <div class="toolbar-actions">
                <button @onclick="LoadAccounts">Apply</button>
                <button class="secondary" @onclick="ClearFilters">Clear</button>
            </div>
        </div>
    </section>

    @if (editing)
    {
        <section class="panel account-editor">
            <div class="section-title-row">
                <div>
                    <p class="eyebrow">Account Setup</p>
                    <h2>@(editModel.Id.HasValue ? "Edit Account" : "New Account")</h2>
                </div>
            </div>
            <div class="form-grid">
                <label>Code
                    <input disabled="@editModel.IsSystemReserved" @bind="editModel.Code" />
                </label>
                <label>Name
                    <input @bind="editModel.Name" />
                </label>
                <label>Type
                    <select disabled="@editModel.IsSystemReserved" @bind="editModel.Type">
                        @foreach (var type in Enum.GetValues<AccountType>())
                        {
                            <option value="@type">@type</option>
                        }
                    </select>
                </label>
                <label class="check-field">
                    <span>Status</span>
                    <input type="checkbox" @bind="editModel.IsActive" />
                    Active
                </label>
                <label class="check-field">
                    <span>Manual Journal</span>
                    <input type="checkbox" @bind="editModel.AllowManualJournal" />
                    Allowed
                </label>
                <label>System
                    <input disabled value="@(editModel.IsSystemReserved ? "Reserved" : "Normal")" />
                </label>
                <label class="wide">Description
                    <input @bind="editModel.Description" />
                </label>
            </div>
            <div class="actions-row">
                <button disabled="@(!CanSaveAccount)" @onclick="SaveAccount">Save Account</button>
                <button class="secondary" @onclick="CancelEdit">Cancel</button>
            </div>
        </section>
    }

    <section class="panel accounts-list-panel">
        <div class="section-title-row">
            <div>
                <p class="eyebrow">Accounts</p>
                <h2>Account Register</h2>
            </div>
            <span class="muted-note">@accounts.Count account@(accounts.Count == 1 ? string.Empty : "s") shown</span>
        </div>

        @if (loading)
        {
            <div class="empty">Loading accounts...</div>
        }
        else if (accounts.Count == 0)
        {
            <div class="empty">No accounts found.</div>
        }
        else
        {
            <div class="account-groups">
                @foreach (var group in AccountGroups)
                {
                    <section class="account-group">
                        <header class="account-group-header">
                            <div class="account-type-title">
                                <span class="type-indicator @TypeClass(group.Type)"></span>
                                <strong>@GroupTitle(group.Type)</strong>
                            </div>
                            <span>@group.Accounts.Count account@(group.Accounts.Count == 1 ? string.Empty : "s") · normal @NormalBalance(group.Type)</span>
                        </header>

                        <div class="account-row account-row-head" aria-hidden="true">
                            <span>Code</span>
                            <span>Name</span>
                            <span>Balance</span>
                            <span>Status</span>
                            <span>Actions</span>
                        </div>

                        @foreach (var account in group.Accounts)
                        {
                            <div class="account-row">
                                <span class="account-code">@account.Code</span>
                                <span class="account-name">
                                    <strong>@account.Name</strong>
                                    @if (!string.IsNullOrWhiteSpace(account.Description))
                                    {
                                        <small>@account.Description</small>
                                    }
                                </span>
                                <span class="normal-balance">@NormalBalance(account.Type)</span>
                                <span>
                                    <span class="@(account.IsActive ? "status-pill status-active" : "status-pill status-inactive")">
                                        @(account.IsActive ? "Active" : "Inactive")
                                    </span>
                                    @if (account.IsSystemReserved)
                                    {
                                        <span class="status-pill status-system">System</span>
                                    }
                                    @if (!account.AllowManualJournal)
                                    {
                                        <span class="status-pill status-locked">Manual blocked</span>
                                    }
                                </span>
                                <span class="row-actions">
                                    <button class="text-button" @onclick="() => EditAccount(account)">Edit</button>
                                    <button class="text-button quiet" @onclick="() => ToggleAccount(account.Id)">@(account.IsActive ? "Deactivate" : "Activate")</button>
                                </span>
                            </div>
                        }
                    </section>
                }
            </div>
        }
    </section>
</div>

@code {
    [Parameter] public int? EntityId { get; set; }

    private static readonly AccountType[] AccountTypeOrder =
    [
        AccountType.Asset,
        AccountType.Liability,
        AccountType.Equity,
        AccountType.Revenue,
        AccountType.Expense
    ];

    private List<Entity> entities = [];
    private Entity? selectedEntity;
    private int selectedEntityId;
    private List<Account> accounts = [];
    private bool loading = true;
    private bool editing;
    private string? search;
    private string? typeFilter;
    private string? statusFilter;
    private AccountForm editModel = new();

    private bool CanSaveAccount => !string.IsNullOrWhiteSpace(editModel.Code) && !string.IsNullOrWhiteSpace(editModel.Name);
    private string SelectedEntityLabel => selectedEntity is null
        ? "Select an entity to maintain its account structure."
        : $"Maintain account structure for {selectedEntity.Code} - {selectedEntity.Name}.";
    private int ActiveAccountCount => accounts.Count(x => x.IsActive);
    private int InactiveAccountCount => accounts.Count(x => !x.IsActive);
    private int DebitNormalCount => accounts.Count(x => NormalBalance(x.Type) == "Debit");
    private int CreditNormalCount => accounts.Count(x => NormalBalance(x.Type) == "Credit");
    private IEnumerable<AccountGroupView> AccountGroups => AccountTypeOrder
        .Select(type => new AccountGroupView(type, accounts.Where(account => account.Type == type).OrderBy(account => account.Code).ToList()))
        .Where(group => group.Accounts.Count > 0);

    protected override async Task OnParametersSetAsync()
    {
        await LoadEntities();
        await LoadAccounts();
    }

    private async Task LoadEntities()
    {
        entities = await Gl.GetEntitiesAsync();
        if (entities.Count == 0)
        {
            entities.Add(await Gl.GetDefaultEntityAsync());
        }

        selectedEntityId = EntityId ?? selectedEntityId;
        if (selectedEntityId == 0 || entities.All(x => x.Id != selectedEntityId))
        {
            selectedEntityId = entities[0].Id;
        }

        selectedEntity = entities.FirstOrDefault(x => x.Id == selectedEntityId);
    }

    private async Task LoadAccounts()
    {
        loading = true;
        AccountType? type = Enum.TryParse<AccountType>(typeFilter, out var parsedType) ? parsedType : null;
        bool? isActive = statusFilter switch
        {
            "active" => true,
            "inactive" => false,
            _ => null
        };

        accounts = selectedEntityId == 0
            ? []
            : await Gl.GetAccountsAsync(selectedEntityId, search, type, isActive);
        loading = false;
    }

    private async Task ChangeEntity(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var entityId))
        {
            selectedEntityId = entityId;
            selectedEntity = entities.FirstOrDefault(x => x.Id == selectedEntityId);
            editing = false;
            await LoadAccounts();
        }
    }

    private async Task ClearFilters()
    {
        search = null;
        typeFilter = null;
        statusFilter = null;
        await LoadAccounts();
    }

    private void NewAccount()
    {
        editModel = new AccountForm();
        editing = true;
    }

    private void EditAccount(Account account)
    {
        editModel = new AccountForm
        {
            Id = account.Id,
            Code = account.Code,
            Name = account.Name,
            Type = account.Type,
            Description = account.Description,
            IsActive = account.IsActive,
            IsSystemReserved = account.IsSystemReserved,
            AllowManualJournal = account.AllowManualJournal
        };
        editing = true;
    }

    private void CancelEdit() => editing = false;

    private async Task SaveAccount()
    {
        await Gl.SaveAccountAsync(new AccountEditDto(editModel.Id, selectedEntityId, editModel.Code, editModel.Name, editModel.Type, editModel.Description, editModel.IsActive, editModel.AllowManualJournal));
        editing = false;
        await LoadAccounts();
    }

    private async Task ToggleAccount(int id)
    {
        await Gl.ToggleAccountAsync(selectedEntityId, id);
        await LoadAccounts();
    }

    private static string NormalBalance(AccountType type) => type is AccountType.Asset or AccountType.Expense ? "Debit" : "Credit";
    private static string GroupTitle(AccountType type) => type switch
    {
        AccountType.Asset => "Assets",
        AccountType.Liability => "Liabilities",
        AccountType.Equity => "Equity",
        AccountType.Revenue => "Revenue",
        AccountType.Expense => "Expenses",
        _ => type.ToString()
    };

    private static string TypeClass(AccountType type) => $"type-{type.ToString().ToLowerInvariant()}";

    private sealed record AccountGroupView(AccountType Type, List<Account> Accounts);

    private sealed class AccountForm
    {
        public int? Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public AccountType Type { get; set; } = AccountType.Asset;
        public string? Description { get; set; }
        public bool IsActive { get; set; } = true;
        public bool IsSystemReserved { get; set; }
        public bool AllowManualJournal { get; set; } = true;
    }
}
