@page "/"
@rendermode InteractiveServer
@inject GeneralLedgerAppService Gl
@inject NavigationManager Nav

<div class="page-header">
    <div>
        <p class="eyebrow">General Ledger</p>
        <h1>Dashboard</h1>
    </div>
    <button @onclick='() => Nav.NavigateTo("/gl/journal-entries/new")'>New Manual Journal</button>
</div>

@if (loading)
{
    <div class="panel empty">Loading dashboard...</div>
}
else if (dashboard is not null)
{
    <div class="stats-grid">
        <div class="stat"><span>Ledger</span><strong>@dashboard.LedgerName</strong></div>
        <div class="stat"><span>Period</span><strong>@dashboard.CurrentPeriod</strong></div>
        <div class="stat"><span>Currency</span><strong>@dashboard.BaseCurrency</strong></div>
        <div class="stat"><span>Accounts</span><strong>@dashboard.AccountsCount</strong></div>
        <div class="stat"><span>Draft / Posted</span><strong>@dashboard.DraftJournalsCount / @dashboard.PostedJournalsCount</strong></div>
    </div>

    <section class="panel">
        <div class="page-header">
            <h2>Latest Journals</h2>
            <a class="button-link secondary" href="/gl/journal-entries">View All</a>
        </div>
        @if (dashboard.LatestJournalEntries.Count == 0)
        {
            <div class="empty">No journal entries yet.</div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Journal No</th>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th class="amount">Debit</th>
                        <th class="amount">Credit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in dashboard.LatestJournalEntries)
                    {
                        <tr>
                            <td><a href="@($"/gl/journal-entries/{entry.Id}")">@entry.JournalNo</a></td>
                            <td>@FormatDate(entry.EntryDate)</td>
                            <td>@entry.Description</td>
                            <td><span class="@StatusClass(entry.Status)">@entry.Status</span></td>
                            <td class="amount">@FormatMoney(entry.TotalDebit)</td>
                            <td class="amount">@FormatMoney(entry.TotalCredit)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    private DashboardDto? dashboard;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        dashboard = await Gl.GetDashboardAsync();
        loading = false;
    }

    private static string FormatDate(DateTime value) => value.ToString("yyyy-MM-dd");
    private static string FormatMoney(decimal value) => value.ToString("N2");
    private static string StatusClass(JournalStatus status) => status switch
    {
        JournalStatus.Posted => "badge badge-posted",
        JournalStatus.Reversed => "badge badge-reversed",
        JournalStatus.Voided => "badge badge-inactive",
        _ => "badge badge-draft"
    };
}
