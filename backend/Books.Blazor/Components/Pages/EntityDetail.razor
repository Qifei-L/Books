@page "/entities/{EntityId:int}"
@rendermode InteractiveServer
@inject GeneralLedgerAppService Gl
@inject NavigationManager Nav

<div class="page-header">
    <div>
        <p class="eyebrow">Entity Detail</p>
        <h1>@(entity is null ? "Entity" : $"{entity.Code} - {entity.Name}")</h1>
    </div>
    <div class="actions-row compact">
        <button class="secondary" @onclick='() => Nav.NavigateTo("/entities")'>Back</button>
        @if (entity is not null)
        {
            <a class="button-link secondary" href="@($"/entities/{entity.Id}/accounts")">Manage Accounts</a>
            <button @onclick="NewLedger">New Ledger</button>
        }
    </div>
</div>

@if (loading)
{
    <div class="panel empty">Loading entity...</div>
}
else if (entity is null)
{
    <div class="panel empty">Entity not found.</div>
}
else
{
    <div class="stats-grid">
        <div class="stat"><span>Entity</span><strong>@entity.Code</strong></div>
        <div class="stat"><span>Accounts</span><strong>@accounts.Count</strong></div>
        <div class="stat"><span>Ledgers</span><strong>@ledgers.Count</strong></div>
        <div class="stat"><span>Selected Ledger</span><strong>@SelectedLedgerCode</strong></div>
        <div class="stat"><span>Journal Entries</span><strong>@entries.Count</strong></div>
    </div>

    @if (editingLedger)
    {
        <section class="panel">
            <div class="section-title-row">
                <div>
                    <p class="eyebrow">Ledger Setup</p>
                    <h2>@(ledgerForm.Id.HasValue ? "Edit Ledger" : "New Ledger")</h2>
                </div>
                <span class="muted-note">@entity.Code - @entity.Name</span>
            </div>
            <div class="form-grid">
                <label>Code
                    <input @bind="ledgerForm.Code" />
                </label>
                <label class="wide">Name
                    <input @bind="ledgerForm.Name" />
                </label>
                <label>Ledger Type
                    <select @bind="ledgerForm.LedgerType">
                        @foreach (var value in Enum.GetValues<LedgerType>())
                        {
                            <option value="@value">@value</option>
                        }
                    </select>
                </label>
                <label class="check-field">
                    <span>Status</span>
                    <input type="checkbox" @bind="ledgerForm.IsActive" />
                    Active
                </label>
                <label class="check-field">
                    <span>Posted Delete</span>
                    <input type="checkbox" @bind="ledgerForm.AllowDeletePostedJournal" />
                    Void posted journals
                </label>
            </div>
            <div class="actions-row">
                <button disabled="@(!CanSaveLedger)" @onclick="SaveLedger">Save Ledger</button>
                <button class="secondary" @onclick="CancelLedgerEdit">Cancel</button>
            </div>
        </section>
    }

    <section class="panel">
        <div class="section-title-row">
            <div>
                <p class="eyebrow">Ledgers</p>
                <h2>Ledger Register</h2>
            </div>
            <span class="muted-note">@ledgers.Count ledger@(ledgers.Count == 1 ? string.Empty : "s")</span>
        </div>

        @if (ledgers.Count == 0)
        {
            <div class="empty">No ledgers found for this entity.</div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>LedgerType</th>
                        <th>IsActive</th>
                        <th>AllowDeletePostedJournal</th>
                        <th class="actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ledger in ledgers)
                    {
                        <tr>
                            <td><button class="text-button" @onclick="() => SelectLedger(ledger.Id)">@ledger.Code</button></td>
                            <td>@ledger.Name</td>
                            <td>@ledger.LedgerType</td>
                            <td><span class="@(ledger.IsActive ? "badge badge-active" : "badge badge-inactive")">@(ledger.IsActive ? "Active" : "Inactive")</span></td>
                            <td>@(ledger.AllowDeletePostedJournal ? "Yes" : "No")</td>
                            <td class="actions">
                                <button class="text-button" @onclick="() => EditLedger(ledger)">Edit</button>
                                <button class="text-button" @onclick="() => OpenLedgerEntries(ledger.Id)">Entries</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="panel">
        <div class="section-title-row">
            <div>
                <p class="eyebrow">Accounts</p>
                <h2>Accounts Under Entity</h2>
            </div>
            <a class="button-link secondary" href="@($"/entities/{entity.Id}/accounts")">Manage Accounts</a>
        </div>

        @if (accounts.Count == 0)
        {
            <div class="empty">No accounts found for this entity.</div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Normal</th>
                        <th>Status</th>
                        <th>Manual Journal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var account in accounts)
                    {
                        <tr>
                            <td>@account.Code</td>
                            <td>@account.Name</td>
                            <td>@account.Type</td>
                            <td>@NormalBalance(account.Type)</td>
                            <td><span class="@(account.IsActive ? "badge badge-active" : "badge badge-inactive")">@(account.IsActive ? "Active" : "Inactive")</span></td>
                            <td>@(account.AllowManualJournal ? "Allowed" : "Blocked")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="panel">
        <div class="section-title-row">
            <div>
                <p class="eyebrow">Journal Entries</p>
                <h2>Entries Under Selected Ledger</h2>
            </div>
            <div class="context-actions">
                <label>Ledger
                    <select value="@selectedLedgerId" @onchange="ChangeSelectedLedger">
                        @foreach (var ledger in ledgers)
                        {
                            <option value="@ledger.Id">@ledger.Code - @ledger.Name</option>
                        }
                    </select>
                </label>
                <button disabled="@(selectedLedgerId == 0)" @onclick="NewJournalForSelectedLedger">New Journal</button>
            </div>
        </div>

        @if (selectedLedgerId == 0)
        {
            <div class="empty">Select a ledger to view journal entries.</div>
        }
        else if (entries.Count == 0)
        {
            <div class="empty">No journal entries for this ledger.</div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Journal No</th>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th class="amount">Debit</th>
                        <th class="amount">Credit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in entries)
                    {
                        <tr>
                            <td><a href="@($"/gl/journal-entries/{entry.Id}")">@entry.JournalNo</a></td>
                            <td>@entry.EntryDate.ToString("yyyy-MM-dd")</td>
                            <td class="truncate">@entry.Description</td>
                            <td><span class="@StatusClass(entry.Status)">@entry.Status</span></td>
                            <td class="amount">@entry.TotalDebit.ToString("N2")</td>
                            <td class="amount">@entry.TotalCredit.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    [Parameter] public int EntityId { get; set; }

    private Entity? entity;
    private List<Account> accounts = [];
    private List<Ledger> ledgers = [];
    private List<JournalEntryListDto> entries = [];
    private LedgerForm ledgerForm = new();
    private int selectedLedgerId;
    private bool editingLedger;
    private bool loading = true;

    private bool CanSaveLedger => !string.IsNullOrWhiteSpace(ledgerForm.Code) && !string.IsNullOrWhiteSpace(ledgerForm.Name);
    private string SelectedLedgerCode => ledgers.FirstOrDefault(x => x.Id == selectedLedgerId)?.Code ?? "-";

    protected override async Task OnParametersSetAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        entity = await Gl.GetEntityAsync(EntityId);
        if (entity is null)
        {
            loading = false;
            return;
        }

        accounts = await Gl.GetAccountsAsync(EntityId, null, null, null);
        ledgers = await Gl.GetLedgersAsync(EntityId);
        if (selectedLedgerId == 0 || ledgers.All(x => x.Id != selectedLedgerId))
        {
            selectedLedgerId = ledgers.FirstOrDefault()?.Id ?? 0;
        }

        await LoadEntries();
        loading = false;
    }

    private async Task LoadEntries()
    {
        entries = selectedLedgerId == 0
            ? []
            : await Gl.GetJournalEntriesAsync(selectedLedgerId);
    }

    private void NewLedger()
    {
        ledgerForm = new LedgerForm();
        editingLedger = true;
    }

    private void EditLedger(Ledger ledger)
    {
        ledgerForm = new LedgerForm
        {
            Id = ledger.Id,
            Code = ledger.Code,
            Name = ledger.Name,
            LedgerType = ledger.LedgerType,
            IsActive = ledger.IsActive,
            AllowDeletePostedJournal = ledger.AllowDeletePostedJournal
        };
        editingLedger = true;
    }

    private void CancelLedgerEdit() => editingLedger = false;

    private async Task SaveLedger()
    {
        var saved = await Gl.SaveLedgerAsync(new LedgerEditDto(
            ledgerForm.Id,
            EntityId,
            ledgerForm.Code,
            ledgerForm.Name,
            ledgerForm.LedgerType,
            ledgerForm.IsActive,
            ledgerForm.AllowDeletePostedJournal));

        selectedLedgerId = saved.Id;
        editingLedger = false;
        await Load();
    }

    private async Task ChangeSelectedLedger(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var ledgerId))
        {
            selectedLedgerId = ledgerId;
            await LoadEntries();
        }
    }

    private async Task SelectLedger(int ledgerId)
    {
        selectedLedgerId = ledgerId;
        await LoadEntries();
    }

    private void OpenLedgerEntries(int ledgerId) => Nav.NavigateTo($"/ledgers/{ledgerId}/journal-entries");

    private void NewJournalForSelectedLedger() => Nav.NavigateTo($"/gl/journal-entries/new?ledgerId={selectedLedgerId}");

    private static string NormalBalance(AccountType type) => type is AccountType.Asset or AccountType.Expense ? "Debit" : "Credit";

    private static string StatusClass(JournalStatus status) => status switch
    {
        JournalStatus.Posted => "badge badge-posted",
        JournalStatus.Reversed => "badge badge-reversed",
        JournalStatus.Voided => "badge badge-inactive",
        _ => "badge badge-draft"
    };

    private sealed class LedgerForm
    {
        public int? Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public LedgerType LedgerType { get; set; } = LedgerType.Main;
        public bool IsActive { get; set; } = true;
        public bool AllowDeletePostedJournal { get; set; } = true;
    }
}
