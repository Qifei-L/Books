@page "/setup/ledger"
@rendermode InteractiveServer
@implements IDisposable
@inject GeneralLedgerAppService Gl
@inject AccountingContextService Context

<div class="page-header">
    <div>
        <p class="eyebrow">Setup</p>
        <h1>Ledger Settings</h1>
    </div>
    <button disabled="@(!canSave)" @onclick="Save">Save</button>
</div>

@if (loading)
{
    <div class="panel empty">Loading ledger settings...</div>
}
else
{
    <section class="panel">
        <div class="form-grid">
            <label>Entity Code
                <input @bind="settings.EntityCode" />
            </label>
            <label>Entity Name
                <input @bind="settings.EntityName" />
            </label>
            <label>Ledger Code
                <input @bind="settings.LedgerCode" />
            </label>
            <label>Ledger Name
                <input @bind="settings.LedgerName" />
            </label>
            <label>Ledger Type
                <select @bind="settings.LedgerType">
                    @foreach (var value in Enum.GetValues<LedgerType>())
                    {
                        <option value="@value">@value</option>
                    }
                </select>
            </label>
            <label>Base Currency
                <input disabled @bind="settings.BaseCurrency" />
            </label>
            <label>Current Period
                <input disabled @bind="settings.CurrentPeriod" />
            </label>
            <label class="check-field">
                <span>Status</span>
                <input type="checkbox" @bind="settings.IsActive" />
                Active
            </label>
            <label class="check-field">
                <span>Posted Delete</span>
                <input type="checkbox" @bind="settings.AllowDeletePostedJournal" />
                Void posted journals
            </label>
        </div>
    </section>
}

@code {
    private LedgerSettingsForm settings = new();
    private bool loading = true;
    private bool canSave =>
        !string.IsNullOrWhiteSpace(settings.EntityCode) &&
        !string.IsNullOrWhiteSpace(settings.EntityName) &&
        !string.IsNullOrWhiteSpace(settings.LedgerCode) &&
        !string.IsNullOrWhiteSpace(settings.LedgerName);

    protected override async Task OnInitializedAsync()
    {
        Context.Changed += ReloadFromContext;
        await Context.InitializeAsync();
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        if (Context.CurrentLedgerId == 0)
        {
            settings = new LedgerSettingsForm();
            loading = false;
            return;
        }

        var dto = await Gl.GetLedgerSettingsAsync(Context.CurrentLedgerId);
        settings = new LedgerSettingsForm
        {
            EntityId = dto.EntityId,
            EntityCode = dto.EntityCode,
            EntityName = dto.EntityName,
            LedgerId = dto.LedgerId,
            LedgerCode = dto.LedgerCode,
            LedgerName = dto.LedgerName,
            LedgerType = dto.LedgerType,
            BaseCurrency = dto.BaseCurrency,
            CurrentPeriod = dto.CurrentPeriod,
            IsActive = dto.IsActive,
            AllowDeletePostedJournal = dto.AllowDeletePostedJournal
        };
        loading = false;
    }

    private async Task Save()
    {
        await Gl.SaveLedgerSettingsAsync(new LedgerSettingsDto(
            settings.EntityId,
            settings.EntityCode,
            settings.EntityName,
            settings.LedgerId,
            settings.LedgerCode,
            settings.LedgerName,
            settings.LedgerType,
            settings.BaseCurrency,
            settings.CurrentPeriod,
            settings.IsActive,
            settings.AllowDeletePostedJournal));
        await Context.SetLedgerAsync(settings.LedgerId);
    }

    private async Task ReloadFromContext()
    {
        await Load();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Context.Changed -= ReloadFromContext;

    private sealed class LedgerSettingsForm
    {
        public int EntityId { get; set; }
        public string EntityCode { get; set; } = string.Empty;
        public string EntityName { get; set; } = string.Empty;
        public int LedgerId { get; set; }
        public string LedgerCode { get; set; } = string.Empty;
        public string LedgerName { get; set; } = string.Empty;
        public LedgerType LedgerType { get; set; } = LedgerType.Main;
        public string BaseCurrency { get; set; } = "USD";
        public string CurrentPeriod { get; set; } = "2026-06";
        public bool IsActive { get; set; } = true;
        public bool AllowDeletePostedJournal { get; set; } = true;
    }
}
