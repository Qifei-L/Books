@page "/documents/ledger"
@rendermode InteractiveServer
@implements IDisposable
@inject AccountingContextService Context

<div class="page-header">
    <div>
        <p class="eyebrow">Documents</p>
        <h1>Ledger Documents</h1>
    </div>
</div>

<section class="panel">
    <div class="section-title-row">
        <div>
            <p class="eyebrow">Current Ledger</p>
            <h2>@(Context.CurrentLedger is null ? "No ledger selected" : $"{Context.CurrentLedger.Code} - {Context.CurrentLedger.Name}")</h2>
        </div>
        <span class="muted-note">Ledger scoped</span>
    </div>

    <div class="empty">No ledger document records are configured yet.</div>
</section>

<section class="panel">
    <div class="section-title-row">
        <div>
            <p class="eyebrow">Extensions</p>
            <h2>Document Field Editor</h2>
        </div>
        <span class="muted-note">FieldKey / Label / FieldType / FieldValue</span>
    </div>

    <div class="form-grid">
        <label>FieldKey
            <input @bind="extensionField.FieldKey" />
        </label>
        <label>Label
            <input @bind="extensionField.Label" />
        </label>
        <label>FieldType
            <select @bind="extensionField.FieldType">
                <option>Text</option>
                <option>Number</option>
                <option>Date</option>
                <option>Boolean</option>
            </select>
        </label>
        <label>FieldValue
            <input @bind="extensionField.FieldValue" />
        </label>
    </div>
    <div class="actions-row">
        <button disabled="@(!CanAddField)" @onclick="AddField">Add Field</button>
        <button class="secondary" @onclick="ClearField">Clear</button>
    </div>

    @if (fields.Count > 0)
    {
        <table>
            <thead>
                <tr>
                    <th>FieldKey</th>
                    <th>Label</th>
                    <th>FieldType</th>
                    <th>FieldValue</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in fields)
                {
                    <tr>
                        <td>@item.FieldKey</td>
                        <td>@item.Label</td>
                        <td>@item.FieldType</td>
                        <td>@item.FieldValue</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private readonly List<DocumentFieldForm> fields = [];
    private DocumentFieldForm extensionField = new();
    private bool CanAddField => !string.IsNullOrWhiteSpace(extensionField.FieldKey) && !string.IsNullOrWhiteSpace(extensionField.Label);

    protected override async Task OnInitializedAsync()
    {
        Context.Changed += ReloadFromContext;
        await Context.InitializeAsync();
    }

    private void AddField()
    {
        fields.Add(new DocumentFieldForm
        {
            FieldKey = extensionField.FieldKey.Trim(),
            Label = extensionField.Label.Trim(),
            FieldType = extensionField.FieldType,
            FieldValue = extensionField.FieldValue?.Trim() ?? string.Empty
        });
        ClearField();
    }

    private void ClearField() => extensionField = new DocumentFieldForm();

    private Task ReloadFromContext()
    {
        fields.Clear();
        return InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Context.Changed -= ReloadFromContext;

    private sealed class DocumentFieldForm
    {
        public string FieldKey { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string FieldType { get; set; } = "Text";
        public string FieldValue { get; set; } = string.Empty;
    }
}
