@page "/reports/general-ledger"
@rendermode InteractiveServer
@inject GeneralLedgerAppService Gl
@inject ReportService ReportsService
@inject ReportExportService Exports
@inject ReportDownloadService Downloads

<div class="page-header">
    <div>
        <p class="eyebrow">Reports</p>
        <h1>General Ledger Report <span class="plum-mark" aria-hidden="true">✣</span></h1>
    </div>
</div>

<section class="panel">
    <div class="toolbar">
        <label>Account
            <select @bind="selectedAccountId">
                <option value="0">Select account</option>
                @foreach (var account in accounts)
                {
                    <option value="@account.Id">@account.Code - @account.Name</option>
                }
            </select>
        </label>
        <span></span>
        <span></span>
        <span></span>
        <button @onclick="LoadRows">Run Report</button>
        <div class="report-actions inline-actions">
            <button class="secondary export-button" disabled="@(!CanExport)" @onclick="ExportExcel">
                <span class="export-icon excel-icon">XLS</span>
                @(exportingFormat == "excel" ? "Exporting..." : "Export Excel")
            </button>
            <button class="secondary export-button" disabled="@(!CanExport)" @onclick="ExportPdf">
                <span class="export-icon pdf-icon">PDF</span>
                @(exportingFormat == "pdf" ? "Exporting..." : "Export PDF")
            </button>
        </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(exportError))
    {
        <div class="error-note">@exportError</div>
    }
</section>

<section class="panel">
    @if (rows.Count == 0)
    {
        <div class="empty">Select an account to view posted journal lines.</div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Journal No</th>
                    <th>Description</th>
                    <th class="amount">Debit</th>
                    <th class="amount">Credit</th>
                    <th class="amount">Balance</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in rows)
                {
                    <tr>
                        <td>@row.EntryDate.ToString("yyyy-MM-dd")</td>
                        <td>@row.JournalNo</td>
                        <td>@row.Description</td>
                        <td class="amount">@row.Debit.ToString("N2")</td>
                        <td class="amount">@row.Credit.ToString("N2")</td>
                        <td class="amount">@row.Balance.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private List<Account> accounts = [];
    private List<GeneralLedgerRowDto> rows = [];
    private int selectedAccountId;
    private int ledgerId;
    private string? exportingFormat;
    private string? exportError;
    private bool CanExport => selectedAccountId > 0 && string.IsNullOrWhiteSpace(exportingFormat);

    protected override async Task OnInitializedAsync()
    {
        var ledger = await Gl.GetDefaultLedgerAsync();
        ledgerId = ledger.Id;
        accounts = await Gl.GetAccountsAsync(null, null, true);
    }

    private async Task LoadRows()
    {
        rows = selectedAccountId > 0 ? await ReportsService.GetGeneralLedgerAsync(ledgerId, selectedAccountId, null, null) : [];
    }

    private async Task Export(string format)
    {
        exportingFormat = format;
        exportError = null;
        try
        {
            var result = format == "excel"
                ? await Exports.ExportGeneralLedgerExcelAsync(ledgerId, selectedAccountId, null, null)
                : await Exports.ExportGeneralLedgerPdfAsync(ledgerId, selectedAccountId, null, null);
            await Downloads.DownloadAsync(result);
        }
        catch (Exception ex)
        {
            exportError = ex.Message;
        }
        finally
        {
            exportingFormat = null;
        }
    }

    private static string Slug(string value)
    {
        var chars = value.ToLowerInvariant().Select(ch => char.IsLetterOrDigit(ch) ? ch : '-').ToArray();
        return string.Join('-', new string(chars).Split('-', StringSplitOptions.RemoveEmptyEntries));
    }

    private Task ExportExcel() => Export("excel");
    private Task ExportPdf() => Export("pdf");
}
