@page "/reports/general-ledger"
@rendermode InteractiveServer
@inject GeneralLedgerAppService Gl
@inject ReportService ReportsService

<div class="page-header">
    <div>
        <p class="eyebrow">Reports</p>
        <h1>General Ledger Report</h1>
    </div>
</div>

<section class="panel">
    <div class="toolbar">
        <label>Account
            <select @bind="selectedAccountId">
                <option value="0">Select account</option>
                @foreach (var account in accounts)
                {
                    <option value="@account.Id">@account.Code - @account.Name</option>
                }
            </select>
        </label>
        <span></span>
        <span></span>
        <span></span>
        <button @onclick="LoadRows">Run Report</button>
        <span></span>
    </div>
</section>

<section class="panel">
    @if (rows.Count == 0)
    {
        <div class="empty">Select an account to view posted journal lines.</div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Journal No</th>
                    <th>Description</th>
                    <th class="amount">Debit</th>
                    <th class="amount">Credit</th>
                    <th class="amount">Balance</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in rows)
                {
                    <tr>
                        <td>@row.EntryDate.ToString("yyyy-MM-dd")</td>
                        <td>@row.JournalNo</td>
                        <td>@row.Description</td>
                        <td class="amount">@row.Debit.ToString("N2")</td>
                        <td class="amount">@row.Credit.ToString("N2")</td>
                        <td class="amount">@row.Balance.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private List<Account> accounts = [];
    private List<GeneralLedgerRowDto> rows = [];
    private int selectedAccountId;
    private int ledgerId;

    protected override async Task OnInitializedAsync()
    {
        var ledger = await Gl.GetDefaultLedgerAsync();
        ledgerId = ledger.Id;
        accounts = await Gl.GetAccountsAsync(null, null, true);
    }

    private async Task LoadRows()
    {
        rows = selectedAccountId > 0 ? await ReportsService.GetGeneralLedgerAsync(ledgerId, selectedAccountId, null, null) : [];
    }
}
