@page "/reports/balance-sheet"
@rendermode InteractiveServer
@inject GeneralLedgerAppService Gl
@inject ReportService ReportsService
@inject ReportExportService Exports
@inject ReportDownloadService Downloads

<div class="page-header">
    <div>
        <p class="eyebrow">Reports</p>
        <h1>Balance Sheet <span class="plum-mark" aria-hidden="true">✣</span></h1>
    </div>
    <div class="report-actions">
        <button class="secondary export-button" disabled="@IsExporting" @onclick="ExportExcel">
            <span class="export-icon excel-icon">XLS</span>
            @(exportingFormat == "excel" ? "Exporting..." : "Export Excel")
        </button>
        <button class="secondary export-button" disabled="@IsExporting" @onclick="ExportPdf">
            <span class="export-icon pdf-icon">PDF</span>
            @(exportingFormat == "pdf" ? "Exporting..." : "Export PDF")
        </button>
        <button class="secondary" @onclick="Load" disabled="@IsExporting">Refresh</button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(exportError))
{
    <div class="error-note">@exportError</div>
}

<section class="panel">
    @if (loading)
    {
        <div class="empty">Loading balance sheet...</div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Account</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th class="amount">Balance</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in rows)
                {
                    <tr>
                        <td>@row.AccountCode</td>
                        <td>@row.AccountName</td>
                        <td>@row.AccountType</td>
                        <td class="amount">@row.Balance.ToString("N2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3">Assets</th>
                    <th class="amount">@Total(AccountType.Asset).ToString("N2")</th>
                </tr>
                <tr>
                    <th colspan="3">Liabilities + Equity</th>
                    <th class="amount">@((Total(AccountType.Liability) + Total(AccountType.Equity)).ToString("N2"))</th>
                </tr>
            </tfoot>
        </table>
    }
</section>

@code {
    private List<FinancialStatementRowDto> rows = [];
    private bool loading = true;
    private int ledgerId;
    private string? exportingFormat;
    private string? exportError;
    private bool IsExporting => !string.IsNullOrWhiteSpace(exportingFormat);

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loading = true;
        var ledger = await Gl.GetDefaultLedgerAsync();
        ledgerId = ledger.Id;
        rows = await ReportsService.GetBalanceSheetAsync(ledger.Id, null, null);
        loading = false;
    }

    private decimal Total(AccountType type) => rows.Where(x => x.AccountType == type).Sum(x => x.Balance);

    private async Task Export(string format)
    {
        exportingFormat = format;
        exportError = null;
        try
        {
            var result = format == "excel"
                ? await Exports.ExportBalanceSheetExcelAsync(ledgerId, null, null)
                : await Exports.ExportBalanceSheetPdfAsync(ledgerId, null, null);
            await Downloads.DownloadAsync(result);
        }
        catch (Exception ex)
        {
            exportError = ex.Message;
        }
        finally
        {
            exportingFormat = null;
        }
    }

    private Task ExportExcel() => Export("excel");
    private Task ExportPdf() => Export("pdf");
}
