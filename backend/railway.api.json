{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "dotnet publish Books.Api/Books.Api.csproj -c Release -o Books.Api/out --no-self-contained"
  },
  "deploy": {
    "startCommand": "dotnet Books.Api/out/Books.Api.dll",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
